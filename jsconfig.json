{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "checkJs": true,
    "maxNodeModuleJsDepth": 0,
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"]
  },
  "include": ["www/js/**/*.js", "scripts/**/*.mjs", "scripts/**/*.js"]
}
